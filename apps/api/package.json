{
  "name": "@possible-cms/api",
  "version": "0.0.0",
  "private": true,
  "description": "Three Cloudflare Workers: admin-api (tRPC), public-api (REST+KV), preview.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply possible-cms --local",
    "db:migrate:remote": "wrangler d1 migrations apply possible-cms --remote"
  },
  "dependencies": {
    "@possible-cms/schema-kit": "workspace:*",
    "@possible-cms/workers-shared": "workspace:*",
    "@trpc/server": "^11.16.0",
    "drizzle-orm": "^0.36.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250418.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "wrangler": "^3.90.0"
  }
}
