{
  "name": "possible-cms",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare-native, open-source CMS for the post-handover phase of AI-delivered websites.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kanousei/possible-cms.git"
  },
  "homepage": "https://github.com/kanousei/possible-cms",
  "bugs": {
    "url": "https://github.com/kanousei/possible-cms/issues"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "grep-gate": "./scripts/grep-gate.sh"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "turbo": "2.3.0",
    "typescript": "5.6.3"
  }
}
