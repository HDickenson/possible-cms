{
  "name": "@possible-cms/blocks",
  "version": "0.0.0",
  "description": "Starter block registry for Possible CMS. Ten blocks covering 90% of marketing pages.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@possible-cms/schema-kit": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "react": "19.0.0",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.4",
    "zod": "3.23.8"
  }
}
