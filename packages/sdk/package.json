{
  "name": "@possible-cms/sdk",
  "version": "0.0.0",
  "description": "Runtime + build-time client for Possible CMS with isomorphic <Render /> component.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./render": {
        "types": "./dist/render.d.ts",
        "import": "./dist/render.js",
        "require": "./dist/render.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/render.tsx --format esm,cjs --dts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}