{
  "name": "@possible-cms/cli",
  "version": "0.0.0",
  "description": "CLI for Possible CMS: init, export, import, doctor.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "possible-cms": "./dist/index.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@possible-cms/sdk": "workspace:*",
    "@possible-cms/schema-kit": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}